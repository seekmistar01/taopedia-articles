{
  "name": "taopedia-articles",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write --config .prettierrc .",
    "format:check": "node scripts/check-prettier-config-safety.mjs && prettier --check --config .prettierrc .",
    "validate": "node scripts/validate-content.mjs",
    "build:index": "npm run validate && node scripts/build-index.mjs",
    "test:index": "node scripts/check-index-publication.mjs",
    "test:internal-links": "node scripts/check-internal-link-validation.mjs",
    "test:published-sources": "node scripts/check-published-source-validation.mjs"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "prettier": "^3.8.3"
  }
}
